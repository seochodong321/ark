rules_version = '2';

// ARK Firestore 보안 규칙
//
// 알려진 한계(응원 씨앗 자가 발행): 응원 씨앗 잔액(users.seedBalance)이
// 클라이언트 SDK 트랜잭션으로 갱신되므로, 본인이 자기 문서의 seedBalance를
// 임의로 늘릴 수 있다. 응원 씨앗은 금전 가치가 없는 활동 포인트이므로
// 현재는 허용한다.
// ⚠️ 금전 가치가 있는 잔액을 도입한다면 절대 이 방식으로 두면 안 된다 —
//    반드시 서버(Admin SDK 또는 Cloud Functions)에서만 잔액을 변경하고,
//    클라이언트의 유료 잔액 직접 쓰기를 규칙으로 금지해야 한다.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isPastor() {
      return isSignedIn() && (userRole() == 'pastor' || userRole() == 'admin');
    }

    function isOwner() {
      return isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // 특정 카운터 필드 하나만 정확히 +1 증가시키는 업데이트인지 검사.
    // 임의 값 설정을 막아 랭킹(조회수·응원수) 조작을 차단한다.
    function isIncrementOnly(field) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([field])
        && request.resource.data[field] is int
        && request.resource.data[field] == resource.data[field] + 1;
    }

    // 특정 카운터 필드 하나만 정확히 ±1 변동시키는 업데이트인지 검사.
    function isCounterDelta(field) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([field])
        && request.resource.data[field] is int
        && (request.resource.data[field] == resource.data[field] + 1
            || request.resource.data[field] == resource.data[field] - 1);
    }

    match /users/{uid} {
      // 공개 프로필 필드만 저장한다(이메일 등 PII는 Firestore에 없음).
      allow read: if true;
      allow create: if isSelf(uid)
        && request.resource.data.role in ['member', 'pastorPending'];
      // 본인은 role·followerCount를 직접 바꿀 수 없다.
      //  - role 승격은 관리자만
      //  - followerCount는 다른 로그인 사용자의 팔로우/언팔로우로만 ±1 변동
      allow update: if isAdmin()
        || (isSelf(uid)
              && request.resource.data.role == resource.data.role
              && request.resource.data.followerCount == resource.data.followerCount)
        || (isSignedIn() && isCounterDelta('followerCount'));
      // 본인 탈퇴 또는 관리자
      allow delete: if isSelf(uid) || isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      // 본인 소유 매핑(탈퇴) 또는 관리자
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    match /pastors/{uid} {
      // 공개 프로필(교회·직분 등)만 담는다. 연락처는 하위 private 문서로 분리.
      allow read: if true;
      // 신청서 작성/재신청은 본인, 승인·반려는 관리자
      allow create: if isSelf(uid)
        && request.resource.data.status == 'pending';
      allow update: if isAdmin()
        || (isSelf(uid) && request.resource.data.status == 'pending');
      // 본인 탈퇴 또는 관리자
      allow delete: if isSelf(uid) || isAdmin();

      // 전화·이메일 등 연락처 — 본인과 관리자만 열람
      match /private/{doc} {
        allow read: if isSelf(uid) || isAdmin();
        allow write: if isSelf(uid);
      }
    }

    // 응원 1회에 보낼 수 있는 씨앗 상한 (CHEER_MAX_PER_ACTION과 일치시킬 것).
    // 로그인 사용자가 seedCount를 1~상한 범위로만 증가시킬 수 있게 해
    // 임의 값 설정(랭킹 조작)을 차단하면서 다중 응원을 허용한다.
    function isSeedCountCheer() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seedCount'])
        && request.resource.data.seedCount is int
        && request.resource.data.seedCount > resource.data.seedCount
        && request.resource.data.seedCount <= resource.data.seedCount + 100;
    }

    // 콘텐츠 카운터 업데이트 검증:
    //  - viewCount: 누구나 +1 (로그아웃 독자의 조회수 반영)
    //  - seedCount: 로그인 사용자의 응원으로만 1~상한 증가
    //  - commentCount: 로그인 사용자의 댓글 작성/삭제로만 ±1
    function isContentCounterUpdate() {
      return isIncrementOnly('viewCount')
        || isSeedCountCheer()
        || (isSignedIn() && isCounterDelta('commentCount'));
    }

    match /sermons/{id} {
      allow read: if resource.data.status == 'published'
        || isOwner() || isAdmin();
      allow create: if isPastor()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.status == 'draft';
      allow update: if isOwner() || isAdmin() || isContentCounterUpdate();
      allow delete: if isOwner() || isAdmin();
    }

    match /testimonies/{id} {
      allow read: if resource.data.status == 'published'
        || isOwner() || isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.status == 'draft';
      allow update: if isOwner() || isAdmin() || isContentCounterUpdate();
      allow delete: if isOwner() || isAdmin();
    }

    match /comments/{id} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isOwner();
      allow delete: if isOwner() || isAdmin();
    }

    match /bookmarks/{id} {
      allow read, delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
    }

    match /reports/{id} {
      allow read, update, delete: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'pending';
    }

    match /seedTransactions/{id} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.uid == request.auth.uid);
      allow update, delete: if false;
    }

    match /notifications/{id} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isAdmin();
      // 읽음 표시만 본인이 변경 가능
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 팔로우 — 본인 명의로만 생성/삭제, 자기 자신 팔로우 금지
    match /follows/{id} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.followerId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.pastorId != request.auth.uid
        && id == request.auth.uid + '_' + request.resource.data.pastorId;
      allow delete: if isSignedIn()
        && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    // 채용 게시판 — 작성은 인증 목회자만, 열람은 누구나
    match /jobs/{id} {
      allow read: if true;
      allow create: if isPastor()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.status == 'open';
      allow update: if isOwner() || isAdmin() || isIncrementOnly('viewCount');
      allow delete: if isOwner() || isAdmin();
    }
  }
}
